# Copy to .env for local development:  cp .env.example .env
# Supabase (Project: parent-finder-hackathon)
SUPABASE_URL=https://ceredhebibmhqxqvxgid.supabase.co
# Service role key - Supabase dashboard > Project Settings > API > service_role.
# Server-side only. NEVER expose to a browser or commit it.
SUPABASE_SERVICE_KEY=

# Anthropic API key (used only for companies not already in the database)
ANTHROPIC_API_KEY=

# Flask session signing key (any random string)
FLASK_SECRET_KEY=change-me

# Max never-seen companies sent to Claude per upload (cost guardrail)
MAX_LLM_LOOKUPS=25
